  "keyFeatures": [
    "Pattern-based URL routing with named variables and regex constraints",
    "Route matching by host, path, HTTP method, schemes, headers, and query values",
    "Subrouters for grouped route namespaces with shared conditions",
    "URL building (reverse routing) from named routes",
    "Middleware support via MiddlewareFunc with ordered execution",
    "Built-in CORSMethodMiddleware for automatic CORS header management",
    "Router.Walk() for programmatic route introspection",
    "Full compatibility with Go's standard net/http.Handler interface"
  ],
  "publicApiSurface": [
    "mux.NewRouter() *Router",
    "Router.HandleFunc(path string, f func(http.ResponseWriter, *http.Request)) *Route",
    "Router.Handle(path string, handler http.Handler) *Route",
    "Router.Host(tpl string) *Route",
    "Router.PathPrefix(tpl string) *Route",
    "Router.Methods(methods ...string) *Route",
    "Router.Schemes(schemes ...string) *Route",
    "Router.Headers(pairs ...string) *Route",
    "Router.Queries(pairs ...string) *Route",
    "Router.Use(mwf ...MiddlewareFunc)",
    "Router.Walk(walkFn WalkFunc) error",
    "Router.StrictSlash(value bool) *Router",
    "Router.SkipClean(value bool) *Router",
    "Router.UseEncodedPath() *Router",
    "Route.Subrouter() *Router",
    "Route.Name(name string) *Route",
    "Route.URL(pairs ...string) (*url.URL, error)",
    "Route.URLPath(pairs ...string) (*url.URL, error)",
    "Route.URLHost(pairs ...string) (*url.URL, error)",
    "Route.GetVarNames() ([]string, error)",
    "Route.Metadata(key any, value any) *Route",
    "mux.Vars(r *http.Request) map[string]string",
    "mux.CurrentRoute(r *http.Request) *Route",
    "mux.CORSMethodMiddleware(r *Router) MiddlewareFunc",
    "type MiddlewareFunc func(http.Handler) http.Handler",
    "type WalkFunc func(route *Route, router *Router, ancestors []*Route) error",
    "type BuildVarsFunc func(map[string]string) map[string]string",
    "ErrMethodMismatch",
    "ErrNotFound",
    "SkipRouter"
  ]
